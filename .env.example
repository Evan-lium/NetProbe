# NetProbe 环境变量配置
# 复制为 .env 并修改（.env 已被 .gitignore 忽略）

# 数据库 URL（不设则用本地 SQLite: data/netprobe.db）
# Docker 部署时由 docker-compose.yml 自动设置
DATABASE_URL=postgresql://netprobe:netprobe123@localhost:5432/netprobe

# JWT 密钥（生产环境务必修改）
NETPROBE_SECRET_KEY=change-this-to-a-random-secret

# 情报源 API Keys（也可在 UI 设置页配置）
# FOFA_EMAIL=
# FOFA_KEY=
# HUNTER_KEY=
# NVD_API_KEY=
# SHODAN_API_KEY=
